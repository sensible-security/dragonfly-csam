# Dragonfly CSAM — deployment configuration template.
# Copy to `.env` (gitignored) and fill in real values before `docker compose up`.
# docker-compose.yml reads these; the app also reads them directly via Deno.env.

# First-boot admin seed. Creates the initial admin ONLY when the users table is
# empty; ignored on every subsequent boot. Password must be >= 12 characters.
DRAGONFLY_ADMIN_USERNAME=admin
DRAGONFLY_ADMIN_PASSWORD=change-me-to-a-long-passphrase

# Set to 1 when a TLS-terminating reverse proxy fronts this plain-HTTP
# container, so session cookies are issued with the Secure attribute.
DRAGONFLY_COOKIE_SECURE=0

# Optional: session lifetime in hours (default 8).
DRAGONFLY_SESSION_TTL_HOURS=8

# Optional: override the embedded DB file path (default /app/data/dragonfly.db,
# which is the mounted volume — leave as-is unless you know why you're changing it).
# DRAGONFLY_DB_PATH=/app/data/dragonfly.db
