{
  "nodeModulesDir": "manual",
  "tasks": {
    "start": "vite",
    "build": "vite build",
    "serve": "deno serve -A _fresh/server.js",
    "test": "deno test -A tests/",
    "check": "deno fmt --check . && deno lint . && deno check",
    "db:migrate": "echo 'db:migrate is a stub until Phase 2 - the migration runner will apply db/migrations/*.sql'",
    "assets:vendor": "deno run --allow-net=data.jsdelivr.com,cdn.jsdelivr.net --allow-read=static/vendor --allow-write=static/vendor tools/vendor_assets.ts",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "fmt": {
    "exclude": [
      "static/vendor/",
      ".agents/",
      "docs/",
      "AGENTS.md",
      "CLAUDE.md",
      "GEMINI.md",
      "README.md"
    ]
  },
  "exclude": [
    "**/_fresh/*",
    "static/vendor/",
    "spikes/"
  ],
  "imports": {
    "@/": "./",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "@std/assert": "jsr:@std/assert@^1.0.13"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}
